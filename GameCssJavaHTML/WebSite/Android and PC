#### **3. The Game Logic (JavaScript)**

Now let's add the logic for combat, including attacking and leveling up:

```javascript
// game.js

let player = {
    health: 100,
    attack: 10,
    level: 1,
    experience: 0
};

let enemy = {
    health: 50
};

// Updates the display for character stats and enemy health
function updateStats() {
    document.getElementById('health').innerText = `Health: ${player.health}`;
    document.getElementById('attack').innerText = `Attack: ${player.attack}`;
    document.getElementById('level').innerText = `Level: ${player.level}`;
    document.getElementById('enemyHealth').innerText = `Enemy Health: ${enemy.health}`;
}

// Function to handle attacks
function attackEnemy() {
    if (enemy.health <= 0) {
        document.getElementById('battleStatus').innerText = "Enemy is already defeated!";
        return;
    }

    // Player attacks enemy
    let damage = Math.floor(Math.random() * player.attack);
    enemy.health -= damage;

    // Check if enemy is defeated
    if (enemy.health <= 0) {
        document.getElementById('battleStatus').innerText = "You defeated the enemy!";
        player.experience += 20;
        levelUp();
    } else {
        document.getElementById('battleStatus').innerText = `You dealt ${damage} damage. Enemy's health: ${enemy.health}`;
    }

    updateStats();
}

// Function for leveling up
function levelUp() {
    if (player.experience >= 100) {
        player.level++;
        player.experience = 0;
        player.attack += 5; // Increase attack power on level-up
        document.getElementById('message').innerText = "Level Up! You are stronger now!";
    }
}

// Event listener for the attack button
document.getElementById('attackButton').addEventListener('click', attackEnemy);

// Initial game state setup
updateStats();
```

#### **4. Running the Game**

Now you can run the game in any modern browser by opening the HTML file. The player can click the "Attack Enemy" button to battle, gain experience, and level up.

